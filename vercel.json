{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "server.js",
      "dest": "api"
    }
  ],
  "env": {
    "MONGODB_URI": "mongodb://localhost:27017/pg_dissertation_db",
    "NODE_ENV": "production",
    "JWT_SECRET": "@jwt_secret",
    "PORT": "3001"
  }
}
